# ElevenLabs — narracja odcinków (TTS). Skopiuj ten plik do .env i wklej swoje wartości.
# .env jest w .gitignore — NIGDY nie commituj prawdziwego klucza.
# Klucz używany jest wyłącznie lokalnie przez scripts/generate-narration.mjs,
# nie trafia do frontendu ani do bundla.

# Klucz API z https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY=

# Domyślne id głosu (https://elevenlabs.io → Voices → wybrany głos → "ID").
# Można nadpisać per odcinek polem voiceId w scripts/narration/episodes.mjs
ELEVENLABS_VOICE_ID=

# --- Formularze (Vercel serverless api/*) ---
# Resend (https://resend.com) — wysyłka maili z newsletter + kontakt.
# 100 maili/dzień darmowo. Bez klucza: api/* loguje w konsoli zamiast wysyłać.
RESEND_API_KEY=
# Adres "From" w wysyłanych mailach (musi być zweryfikowaną domeną w Resend).
MAIL_FROM=OBSKURA <no-reply@obskura.app>
# Skrzynka do której kierowane są maile z /api/contact.
CONTACT_INBOX=kontakt@obskura.app
